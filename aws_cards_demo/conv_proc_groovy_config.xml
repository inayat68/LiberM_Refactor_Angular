<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<divergeek_converter xmlns="https://www.mlogica.com">
	<properties>
		<property name="create_date" value="2026-04-16 11:08:33.872"/>
		<property name="project_name" value="AWS_CARDS_DEMO"/>
		<property name="rights" value="mLogica"/>
		<!--
			One of the following values:
			jcl
			proc
			cobol
			bms
		-->
		<property name="converter" value="proc"/>
		<property name="workspace" value="ENV{DG_CONV_WORKSPACE_IN}"/>
		<property name="delivery_project_root" value="ENV{DG_CONV_WORKSPACE_OUT}"/>
		<property name="profile" value="jcl_groovy_profile"/>
		<property name="skeleton" value="skeleton_proc_groovy.txt"/>
	</properties>
	<resources>
		<resource pattern="*" location="sources\proc" output="${delivery_project_root}\src\main\groovy\procs" />
	</resources>
	<converter_settings>
		<setting name="target_syntax" value="GROOVY" />
		<setting name="target_os" value="linux" />
		<setting name="target_db" value="PGSQL" />
		<setting name="output_embedded_cards" value="${delivery_project_root}\jcl-root\files" />
		<setting name="procs_location" value="${workspace}\sources\proc" />
		<setting name="procs_package" value="procs" />
		<setting name="includes_location" value="${workspace}\sources\proc" />
		<setting name="ccards_location" value="${workspace}\sources\ctl" />
		<setting name="ignore_severe_errors" value="false" />
	</converter_settings>
</divergeek_converter>
