*>****************************************************************
*> Plain text exit - Dont use in production                      *
*>****************************************************************
SEND-PLAIN-TEXT.
    EXEC CICS SEND TEXT
              FROM(WS-RETURN-MSG)
              LENGTH(LENGTH OF WS-RETURN-MSG)
              ERASE
              FREEKB
    END-EXEC
*>
    EXEC CICS RETURN
    END-EXEC
    .
SEND-PLAIN-TEXT-EXIT.
    EXIT
    .
*>****************************************************************
*> Display Long text and exit                                    *
*> This is primarily for debugging and should not be used in     *
*> regular course                                                *
*>****************************************************************
SEND-LONG-TEXT.
    EXEC CICS SEND TEXT
              FROM(WS-LONG-MSG)
              LENGTH(LENGTH OF WS-LONG-MSG)
              ERASE
              FREEKB
    END-EXEC
*>
    EXEC CICS RETURN
    END-EXEC
    .
SEND-LONG-TEXT-EXIT.
    EXIT
