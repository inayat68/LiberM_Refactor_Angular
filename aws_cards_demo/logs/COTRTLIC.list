*> either express or implied. See the License for the specific
*> language governing permissions and limitations under the License
*>****************************************************************
*> Dummy call to verify connectivity to Db2                      *
*>****************************************************************
9998-PRIMING-QUERY.

    EXEC SQL
         SELECT 1
           INTO :WS-DUMMY-DB2-INT
           FROM SYSIBM.SYSDUMMY1
           FETCH FIRST 1 ROW ONLY
    END-EXEC


    MOVE SQLCODE        TO WS-DISP-SQLCODE

    EVALUATE TRUE
       WHEN SQLCODE = ZERO
          CONTINUE
       WHEN OTHER
*>          This is some kind of error. Format message and exit
          SET WS-DB2-ERROR        TO TRUE

          MOVE 'Db2 access failure. '
                                       TO WS-DB2-CURRENT-ACTION
          PERFORM 9999-FORMAT-DB2-MESSAGE
             THRU 9999-FORMAT-DB2-MESSAGE-EXIT
     END-EVALUATE
    .
9998-PRIMING-QUERY-EXIT.
    EXIT
    .
*>****************************************************************
*> Construct formatted message using DSNTIAC utility             *
*> This is for Db2                                               *
*>****************************************************************
9999-FORMAT-DB2-MESSAGE.

    MOVE +72                 TO WS-DSNTIAC-LRECL

    CALL LIT-DSNTIAC  USING  DFHEIBLK,
                             DFHCOMMAREA,
                             SQLCA,
                             WS-DSNTIAC-FORMATTED,
                             WS-DSNTIAC-LRECL
    END-CALL

    COMPUTE WS-DSNTIAC-ERR-CD = RETURN-CODE


    IF WS-DSNTIAC-ERR-CD = ZEROES
       CONTINUE
    ELSE
       MOVE 'DSNTIAC CD: '       TO WS-DSNTIAC-ERR-MSG
       MOVE WS-DSNTIAC-ERROR     TO WS-DSNTIAC-FMTD-TEXT
    END-IF

    STRING
         FUNCTION TRIM(WS-DB2-CURRENT-ACTION)
                  ' SQLCODE:'
                  WS-DISP-SQLCODE
                  ' '
*>                  SQLERRM OF SQLCA
                  WS-DSNTIAC-FMTD-TEXT
         DELIMITED BY SIZE
    INTO WS-LONG-MSG
    END-STRING
    MOVE WS-LONG-MSG       TO WS-RETURN-MSG
    .

9999-FORMAT-DB2-MESSAGE-EXIT.
    EXIT
    .
