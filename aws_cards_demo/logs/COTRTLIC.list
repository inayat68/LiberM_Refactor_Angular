*>****************************************************************
*>COPY 'CSSTRPFY'
*>    .
*>vvv-> file: C:\Users\Sethulekshmi.Pishara\Work\LiberTools\CLERITY\Converter\aws_cards_demo\sources\cpy\CSSTRPFY.cpy
