*>
*> Unless required by applicable law or agreed to in writing,
*> software distributed under the License is distributed on an
*> "AS IS" BASIS, WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND,
*> either express or implied. See the License for the specific
*> language governing permissions and limitations under the License
*>*****************************************************************
*>    Set (TESTVAR1) to red if in error and * if blankACSHLIM
    IF (FLG-DESCRIPTION-NOT-OK
    OR  FLG-DESCRIPTION-BLANK)
    AND CDEMO-PGM-REENTER
        MOVE DFHRED             TO
             TRTYDSCC OF CTRTUPAO
        IF  FLG-DESCRIPTION-BLANK
            MOVE '*'            TO
             TRTYDSCO OF CTRTUPAO
        END-IF
    END-IF
*>
*> Ver: CardDemo_v1.0-15-g27d6c6f-68 Date: 2022-07-19 23:15:58 CDT
*>
*>^^^-> file: C:\Users\Sethulekshmi.Pishara\Work\LiberTools\CLERITY\Converter\aws_cards_demo\sources\cpy\CSSETATY.cpy

    .
3300-SETUP-SCREEN-ATTRS-EXIT.
    EXIT
    .

3310-PROTECT-ALL-ATTRS.
    MOVE DFHBMPRF              TO TRTYPCDA OF CTRTUPAI
                                  TRTYDSCA OF CTRTUPAI
                                  INFOMSGA OF CTRTUPAI
    .
3310-PROTECT-ALL-ATTRS-EXIT.
    EXIT
    .

3320-UNPROTECT-FEW-ATTRS.

    MOVE DFHBMFSE              TO TRTYDSCA OF CTRTUPAI
    MOVE DFHBMPRF              TO INFOMSGA OF CTRTUPAI
    .
3320-UNPROTECT-FEW-ATTRS-EXIT.
    EXIT
    .

3390-SETUP-INFOMSG-ATTRS.
    IF  WS-NO-INFO-MESSAGE
        MOVE DFHBMDAR           TO INFOMSGA OF CTRTUPAI
    ELSE
        MOVE DFHBMASB           TO INFOMSGA OF CTRTUPAI
    END-IF
    .
3390-SETUP-INFOMSG-ATTRS-EXIT.
    EXIT
    .

3391-SETUP-PFKEY-ATTRS.
*>    Should reflect in 0001-CHECK-PFKEYS
*>    Enter key
    IF TTUP-CONFIRM-DELETE
       MOVE DFHBMDAR            TO FKEYSA   OF CTRTUPAI
    ELSE
       MOVE DFHBMASB            TO FKEYSA   OF CTRTUPAI
    END-IF
*>    F4
    IF TTUP-SHOW-DETAILS
    OR TTUP-CONFIRM-DELETE
        MOVE DFHBMASB           TO FKEY04A  OF CTRTUPAI
    END-IF
*>    F5
    IF TTUP-CHANGES-OK-NOT-CONFIRMED
    OR TTUP-DETAILS-NOT-FOUND
        MOVE DFHBMASB           TO FKEY05A  OF CTRTUPAI
    END-IF
*>    F12
    IF TTUP-CHANGES-OK-NOT-CONFIRMED
    OR TTUP-SHOW-DETAILS
    OR TTUP-DETAILS-NOT-FOUND
    OR TTUP-CONFIRM-DELETE
    OR TTUP-CREATE-NEW-RECORD
        MOVE DFHBMASB           TO FKEY12A  OF CTRTUPAI
    END-IF
    .
3391-SETUP-PFKEY-ATTRS-EXIT.
    EXIT
    .

3400-SEND-SCREEN.

    MOVE LIT-THISMAPSET         TO CCARD-NEXT-MAPSET
    MOVE LIT-THISMAP            TO CCARD-NEXT-MAP

    EXEC CICS SEND MAP(CCARD-NEXT-MAP)
                   MAPSET(CCARD-NEXT-MAPSET)
                   FROM(CTRTUPAO)
                   CURSOR
                   ERASE
                   FREEKB
                   RESP(WS-RESP-CD)
    END-EXEC
    .
3400-SEND-SCREEN-EXIT.
    EXIT
    .


9000-READ-TRANTYPE.

    INITIALIZE TTUP-OLD-DETAILS

    SET  WS-NO-INFO-MESSAGE      TO TRUE

    PERFORM 9100-GET-TRANSACTION-TYPE
       THRU 9100-GET-TRANSACTION-TYPE-EXIT

    IF FLG-TRANFILTER-NOT-OK
       GO TO 9000-READ-TRANTYPE-EXIT
    END-IF


    PERFORM 9500-STORE-FETCHED-DATA
       THRU 9500-STORE-FETCHED-DATA-EXIT
    .


9000-READ-TRANTYPE-EXIT.
    EXIT
    .
9100-GET-TRANSACTION-TYPE.

*>    Read the Card file. Access via alternate index ACCTID
*>
    MOVE TTUP-NEW-TTYP-TYPE TO DCL-TR-TYPE

    EXEC SQL
         SELECT TR_TYPE
               ,TR_DESCRIPTION
           INTO :DCL-TR-TYPE
               ,:DCL-TR-DESCRIPTION
           FROM CARDDEMO.TRANSACTION_TYPE
          WHERE TR_TYPE = :DCL-TR-TYPE
    END-EXEC

    MOVE SQLCODE                            TO WS-DISP-SQLCODE

    EVALUATE TRUE
        WHEN SQLCODE = ZERO
           SET FOUND-TRANTYPE-IN-TABLE     TO TRUE
        WHEN SQLCODE = +100
           SET INPUT-ERROR                 TO TRUE
           SET FLG-TRANFILTER-NOT-OK       TO TRUE
           IF WS-RETURN-MSG-OFF
             SET WS-RECORD-NOT-FOUND       TO TRUE
           END-IF
        WHEN SQLCODE < 0
           SET INPUT-ERROR                 TO TRUE
           SET FLG-TRANFILTER-NOT-OK       TO TRUE
           IF WS-RETURN-MSG-OFF
             STRING
             'Error accessing:'
             ' TRANSACTION_TYPE table. SQLCODE:'
             WS-DISP-SQLCODE
             ':'
             SQLERRM OF SQLCA
             DELIMITED BY SIZE
             INTO WS-RETURN-MSG
             END-STRING
           END-IF
    END-EVALUATE
    EXIT
    .
9100-GET-TRANSACTION-TYPE-EXIT.
    EXIT
    .


9500-STORE-FETCHED-DATA.

    INITIALIZE TTUP-OLD-DETAILS
*>*****************************************************************
*>    Transaction Type data
*>*****************************************************************
    MOVE DCL-TR-TYPE         TO TTUP-OLD-TTYP-TYPE
    MOVE DCL-TR-DESCRIPTION-TEXT(1: DCL-TR-DESCRIPTION-LEN)
                             TO TTUP-OLD-TTYP-TYPE-DESC

    .
9500-STORE-FETCHED-DATA-EXIT.
    EXIT
    .
9600-WRITE-PROCESSING.

*>****************************************************************
*> Update Transaction Type *
*>****************************************************************
*>    Issue Update
*>
    MOVE TTUP-NEW-TTYP-TYPE TO DCL-TR-TYPE
    MOVE FUNCTION TRIM(TTUP-NEW-TTYP-TYPE-DESC)
                            TO DCL-TR-DESCRIPTION-TEXT
    COMPUTE DCL-TR-DESCRIPTION-LEN
     = FUNCTION LENGTH(TTUP-NEW-TTYP-TYPE-DESC)

    EXEC SQL
         UPDATE CARDDEMO.TRANSACTION_TYPE
            SET TR_DESCRIPTION = :DCL-TR-DESCRIPTION
          WHERE TR_TYPE = :DCL-TR-TYPE
    END-EXEC

*>****************************************************************
*> Did Transaction Type update succeed ?  *
*>****************************************************************
    MOVE SQLCODE                       TO WS-DISP-SQLCODE

    EVALUATE TRUE
        WHEN SQLCODE = ZERO
           EXEC CICS SYNCPOINT END-EXEC
        WHEN SQLCODE = +100
           PERFORM 9700-INSERT-RECORD
              THRU 9700-INSERT-RECORD-EXIT
        WHEN SQLCODE = -911
           SET INPUT-ERROR                    TO TRUE
           IF  WS-RETURN-MSG-OFF
               SET COULD-NOT-LOCK-REC-FOR-UPDATE
                                              TO TRUE
           END-IF
        WHEN SQLCODE < 0
           SET TABLE-UPDATE-FAILED            TO TRUE
             STRING
             'Error updating:'
             ' TRANSACTION_TYPE Table. SQLCODE:'
             WS-DISP-SQLCODE
             ':'
             SQLERRM OF SQLCA
             DELIMITED BY SIZE
             INTO WS-RETURN-MSG
             END-STRING
    END-EVALUATE

    EVALUATE TRUE
       WHEN COULD-NOT-LOCK-REC-FOR-UPDATE
            SET TTUP-CHANGES-OKAYED-LOCK-ERROR TO TRUE
       WHEN TABLE-UPDATE-FAILED
            SET TTUP-CHANGES-OKAYED-BUT-FAILED TO TRUE
       WHEN DATA-WAS-CHANGED-BEFORE-UPDATE
            SET TTUP-SHOW-DETAILS              TO TRUE
       WHEN OTHER
          SET TTUP-CHANGES-OKAYED-AND-DONE     TO TRUE
    END-EVALUATE

    EXIT
    .
9600-WRITE-PROCESSING-EXIT.
    EXIT
    .
9700-INSERT-RECORD.
    EXEC SQL
         INSERT INTO CARDDEMO.TRANSACTION_TYPE
                    (TR_TYPE, TR_DESCRIPTION)
            VALUES ( :DCL-TR-TYPE
                    ,:DCL-TR-DESCRIPTION)
    END-EXEC

    EVALUATE TRUE
        WHEN SQLCODE = ZERO
           EXEC CICS SYNCPOINT END-EXEC
        WHEN OTHER
           SET TABLE-UPDATE-FAILED            TO TRUE
             STRING
             'Error inserting record into:'
             ' TRANSACTION_TYPE Table. SQLCODE:'
             WS-DISP-SQLCODE
             ':'
             SQLERRM OF SQLCA
             DELIMITED BY SIZE
             INTO WS-RETURN-MSG
             END-STRING
           GO TO 9700-INSERT-RECORD-EXIT
    END-EVALUATE
    .
9700-INSERT-RECORD-EXIT.
    EXIT
    .
9800-DELETE-PROCESSING.
    MOVE TTUP-OLD-TTYP-TYPE TO DCL-TR-TYPE

    EXEC SQL
         DELETE FROM CARDDEMO.TRANSACTION_TYPE
          WHERE TR_TYPE = :DCL-TR-TYPE
    END-EXEC

    MOVE SQLCODE                             TO WS-DISP-SQLCODE

    EVALUATE TRUE
        WHEN SQLCODE = ZERO
           SET TTUP-DELETE-DONE              TO TRUE
           EXEC CICS SYNCPOINT END-EXEC
        WHEN SQLCODE = -532
           SET RECORD-DELETE-FAILED          TO TRUE
             STRING
             'Please delete associated child records first:'
             'SQLCODE :'
             WS-DISP-SQLCODE
             ':'
             SQLERRM OF SQLCA
             SQLERRM OF SQLCA
             DELIMITED BY SIZE
             INTO WS-RETURN-MSG
             END-STRING
        WHEN OTHER
           SET RECORD-DELETE-FAILED          TO TRUE
           SET TTUP-DELETE-FAILED            TO TRUE
             STRING
             'Delete failed with message:'
             'SQLCODE :'
             WS-DISP-SQLCODE
             ':'
             SQLERRM OF SQLCA
             DELIMITED BY SIZE
             INTO WS-RETURN-MSG
             END-STRING
    END-EVALUATE
    .
9800-DELETE-PROCESSING-EXIT.
    EXIT
    .

