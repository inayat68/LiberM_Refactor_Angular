01 WS-THIS-PROGCOMMAREA.
   05 TTUP-UPDATE-SCREEN-DATA.
      10 TTUP-CHANGE-ACTION                     PIC X(1)
                                                VALUE LOW-VALUES.
         88 TTUP-DETAILS-NOT-FETCHED            VALUES
                                                LOW-VALUES,
                                                SPACES.
         88 TTUP-INVALID-SEARCH-KEYS            VALUE 'K'.
         88 TTUP-DETAILS-NOT-FOUND              VALUE 'X'.
         88 TTUP-SHOW-DETAILS                   VALUE 'S'.
*>
         88 TTUP-CREATE-NEW-RECORD              VALUE 'R'.
         88 TTUP-REVIEW-NEW-RECORD              VALUE 'V'.
         88 TTUP-DELETE-IN-PROGRESS             VALUES '9'
                                                     , '8', '7'
                                                     , '6'.
         88 TTUP-CONFIRM-DELETE                 VALUE '9'.
         88 TTUP-START-DELETE                   VALUE '8'.
         88 TTUP-DELETE-DONE                    VALUE '7'.
         88 TTUP-DELETE-FAILED                  VALUE '6'.
*>**
         88 TTUP-CHANGES-MADE                   VALUES 'E', 'N'
                                                     , 'L'
                                                     , 'F'.
         88 TTUP-CHANGES-NOT-OK                 VALUE 'E'.
         88 TTUP-CHANGES-OK-NOT-CONFIRMED       VALUE 'N'.

*>**
         88 TTUP-CHANGES-FAILED                 VALUES 'L', 'F'.
         88 TTUP-CHANGES-OKAYED-LOCK-ERROR      VALUE 'L'.
         88 TTUP-CHANGES-OKAYED-BUT-FAILED      VALUE 'F'.

         88 TTUP-CHANGES-OKAYED-AND-DONE        VALUE 'C'.
         88 TTUP-CHANGES-BACKED-OUT             VALUE 'B'.
   05 TTUP-OLD-DETAILS.
      10 TTUP-OLD-TTYP-DATA.
         15  TTUP-OLD-TTYP-TYPE                 PIC X(02).
         15  TTUP-OLD-TTYP-TYPE-DESC            PIC X(50).
   05 TTUP-NEW-DETAILS.
      10 TTUP-NEW-TTYP-DATA.
         15  TTUP-NEW-TTYP-TYPE                 PIC X(02).
         15  TTUP-NEW-TTYP-TYPE-DESC            PIC X(50).
01  WS-COMMAREA                                 PIC X(2000).


LINKAGE SECTION.
01  DFHCOMMAREA.
  05  FILLER                                PIC X(1)
      OCCURS 1 TO 32767 TIMES DEPENDING ON EIBCALEN.

PROCEDURE DIVISION.
0000-MAIN.


    EXEC CICS HANDLE ABEND
              LABEL(ABEND-ROUTINE)
    END-EXEC

    INITIALIZE CC-WORK-AREA
               WS-MISC-STORAGE
               WS-COMMAREA
*>****************************************************************
*> Store our context
*>****************************************************************
    MOVE LIT-THISTRANID       TO WS-TRANID
*>****************************************************************
*> Ensure error message is cleared                               *
*>****************************************************************
    SET WS-RETURN-MSG-OFF  TO TRUE
*>****************************************************************
*> Store passed data if  any                *
*>****************************************************************
    IF EIBCALEN IS EQUAL TO 0
        OR (CDEMO-FROM-PROGRAM = LIT-ADMINPGM
        AND NOT CDEMO-PGM-REENTER)
        OR (CDEMO-FROM-PROGRAM = LIT-LISTTPGM
        AND NOT CDEMO-PGM-REENTER)
       INITIALIZE CARDDEMO-COMMAREA
                  WS-THIS-PROGCOMMAREA
       SET CDEMO-PGM-ENTER TO TRUE
       SET TTUP-DETAILS-NOT-FETCHED TO TRUE
    ELSE
       MOVE DFHCOMMAREA (1:LENGTH OF CARDDEMO-COMMAREA)  TO
                         CARDDEMO-COMMAREA
       MOVE DFHCOMMAREA(LENGTH OF CARDDEMO-COMMAREA + 1:
                        LENGTH OF WS-THIS-PROGCOMMAREA ) TO
                         WS-THIS-PROGCOMMAREA
    END-IF
*>****************************************************************
*> Store the Mapped PF Key
*> Remap PFkeys as needed.
*>****************************************************************
    PERFORM YYYY-STORE-PFKEY
       THRU YYYY-STORE-PFKEY-EXIT

*>****************************************************************
*> Check the AID to see if its valid at this point               *
*> Change the key to some valid value if possible
*> F3 - Exit
*> Enter show screen again
*> F4 - Delete
*> F5 - Save
*> F12 - Cancel
*>****************************************************************
    SET PFK-INVALID TO TRUE

    PERFORM 0001-CHECK-PFKEYS
       THRU 0001-CHECK-PFKEYS-EXIT
*>****************************************************************
*>       Simulate initial entry if the following flags are set
*>****************************************************************
    EVALUATE TRUE
       WHEN CCARD-AID-PFK12
        AND (TTUP-SHOW-DETAILS
         OR  TTUP-CREATE-NEW-RECORD
         OR  TTUP-DETAILS-NOT-FOUND)
       WHEN TTUP-CHANGES-OKAYED-AND-DONE
       WHEN TTUP-CHANGES-FAILED
       WHEN TTUP-CHANGES-BACKED-OUT
        AND  (TTUP-OLD-DETAILS EQUAL LOW-VALUES
         OR   TTUP-OLD-DETAILS EQUAL SPACES)
       WHEN TTUP-DELETE-DONE
       WHEN TTUP-DELETE-FAILED
            SET CDEMO-PGM-ENTER          TO TRUE
            SET TTUP-DETAILS-NOT-FETCHED TO TRUE
    END-EVALUATE
*>****************************************************************
*> Decide what to do based on PF KEY PRESSED AND CONTEXT
*>****************************************************************
    EVALUATE TRUE
*>*****************************************************************
*>       USER PRESSES PF03 TO EXIT
*>  OR   USER IS DONE WITH UPDATE
*>            XCTL TO CALLING PROGRAM OR MAIN MENU
*>*****************************************************************
       WHEN CCARD-AID-PFK03

            IF CDEMO-FROM-TRANID    EQUAL LOW-VALUES
            OR CDEMO-FROM-TRANID    EQUAL SPACES
               MOVE LIT-ADMINTRANID   TO CDEMO-TO-TRANID
            ELSE
               MOVE CDEMO-FROM-TRANID TO CDEMO-TO-TRANID
            END-IF

            IF CDEMO-FROM-PROGRAM   EQUAL LOW-VALUES
            OR CDEMO-FROM-PROGRAM   EQUAL SPACES
               MOVE LIT-ADMINPGM     TO CDEMO-TO-PROGRAM
            ELSE
               MOVE CDEMO-FROM-PROGRAM TO CDEMO-TO-PROGRAM
            END-IF

            MOVE LIT-THISTRANID     TO CDEMO-FROM-TRANID
            MOVE LIT-THISPGM        TO CDEMO-FROM-PROGRAM

            SET  CDEMO-USRTYP-ADMIN TO TRUE
            SET  CDEMO-PGM-ENTER    TO TRUE
            MOVE LIT-THISMAPSET     TO CDEMO-LAST-MAPSET
            MOVE LIT-THISMAP        TO CDEMO-LAST-MAP

            EXEC CICS
                 SYNCPOINT
            END-EXEC

            EXEC CICS XCTL
                 PROGRAM (CDEMO-TO-PROGRAM)
                 COMMAREA(CARDDEMO-COMMAREA)
            END-EXEC
*>*****************************************************************
*>       CLEAR SCREEN, CLEAR SAVED CONTEXT
*>       ASK USER FOR SEARCH KEYS
*>*****************************************************************
       WHEN NOT CDEMO-PGM-REENTER
        AND CDEMO-FROM-PROGRAM   EQUAL LIT-ADMINPGM
       WHEN NOT CDEMO-PGM-REENTER
        AND CDEMO-FROM-PROGRAM   EQUAL LIT-LISTTPGM
       WHEN CDEMO-PGM-ENTER
        AND TTUP-DETAILS-NOT-FETCHED
            INITIALIZE WS-THIS-PROGCOMMAREA
                       WS-MISC-STORAGE
                       CDEMO-ACCT-ID
            PERFORM 3000-SEND-MAP THRU
                    3000-SEND-MAP-EXIT
            SET CDEMO-PGM-REENTER        TO TRUE
            SET TTUP-DETAILS-NOT-FETCHED TO TRUE
            GO TO COMMON-RETURN
*>*****************************************************************
*>       USER PRESSED F04 AFTER BEING ASKED TO VERIFY DELETE
*>*****************************************************************
       WHEN CCARD-AID-PFK04
        AND TTUP-CONFIRM-DELETE
            SET TTUP-START-DELETE                TO TRUE
            PERFORM 9800-DELETE-PROCESSING
               THRU 9800-DELETE-PROCESSING-EXIT
            PERFORM 3000-SEND-MAP THRU
                    3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
*>*****************************************************************
*>       USER PRESSED F04.ASK FOR DELETE CONFIRMATION
*>*****************************************************************
       WHEN CCARD-AID-PFK04
        AND TTUP-SHOW-DETAILS
            SET TTUP-CONFIRM-DELETE              TO TRUE
            PERFORM 3000-SEND-MAP THRU
                    3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
*>*****************************************************************
*>       USER PRESSED F05. WHEN NO RECORD WAS FOUND.
*>       ASK TO CONFIRM NEW RECORD CREATION
*>*****************************************************************
       WHEN CCARD-AID-PFK05
        AND TTUP-DETAILS-NOT-FOUND
           SET TTUP-CREATE-NEW-RECORD TO TRUE
            PERFORM 3000-SEND-MAP THRU
                    3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
*>*****************************************************************
*>       USER PRESSED F05 AND CONFIRMED THAT CHANGES CAN BE SAVED
*>       EDITS HAVE PASSED
*>       SO SAVE THE CHANGES
*>*****************************************************************
       WHEN CCARD-AID-PFK05
        AND TTUP-CHANGES-OK-NOT-CONFIRMED
          PERFORM 9600-WRITE-PROCESSING
             THRU 9600-WRITE-PROCESSING-EXIT
            PERFORM 3000-SEND-MAP
               THRU 3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
*>*****************************************************************
*>       USER PRESSED F12. CANCEL THE ACTION
*>*****************************************************************
        WHEN CCARD-AID-PFK12
        AND (TTUP-CHANGES-OK-NOT-CONFIRMED
         OR  TTUP-CONFIRM-DELETE
         OR  TTUP-SHOW-DETAILS)
            SET FOUND-TRANTYPE-IN-TABLE  TO TRUE
            PERFORM 2000-DECIDE-ACTION
               THRU 2000-DECIDE-ACTION-EXIT
            PERFORM 3000-SEND-MAP
               THRU 3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
*>*****************************************************************
*>       CHECK THE USER INPUTS
*>       DECIDE WHAT TO DO
*>       PRESENT NEXT STEPS TO USER
*>*****************************************************************
       WHEN WS-INVALID-KEY-PRESSED
            PERFORM 3000-SEND-MAP
               THRU 3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
*>*****************************************************************
*>       CHECK THE USER INPUTS
*>       DECIDE WHAT TO DO
*>       PRESENT NEXT STEPS TO USER
*>*****************************************************************
       WHEN OTHER
            PERFORM 1000-PROCESS-INPUTS
               THRU 1000-PROCESS-INPUTS-EXIT
            PERFORM 2000-DECIDE-ACTION
               THRU 2000-DECIDE-ACTION-EXIT
            PERFORM 3000-SEND-MAP
               THRU 3000-SEND-MAP-EXIT
            GO TO COMMON-RETURN
    END-EVALUATE
    .

COMMON-RETURN.
    MOVE WS-RETURN-MSG     TO CCARD-ERROR-MSG

    MOVE  CARDDEMO-COMMAREA    TO WS-COMMAREA
    MOVE  WS-THIS-PROGCOMMAREA TO
           WS-COMMAREA(LENGTH OF CARDDEMO-COMMAREA + 1:
                        LENGTH OF WS-THIS-PROGCOMMAREA )

    EXEC CICS RETURN
         TRANSID (LIT-THISTRANID)
         COMMAREA (WS-COMMAREA)
         LENGTH(LENGTH OF WS-COMMAREA)
    END-EXEC
    .
0000-MAIN-EXIT.
    EXIT
    .

0001-CHECK-PFKEYS.

*>    Should mirror logic in PFKey attribut para
*>    3391-PFKEY-ATTRS

    IF (CCARD-AID-PFK03)
    OR (CCARD-AID-ENTER AND NOT TTUP-CONFIRM-DELETE)
    OR (CCARD-AID-PFK04 AND (TTUP-SHOW-DETAILS
                       OR   TTUP-CONFIRM-DELETE )
       )

    OR (CCARD-AID-PFK05 AND (
                            TTUP-CHANGES-OK-NOT-CONFIRMED
                       OR   TTUP-DETAILS-NOT-FOUND
                       OR   TTUP-DELETE-IN-PROGRESS
                            )
       )
    OR (CCARD-AID-PFK12 AND (
                            TTUP-CHANGES-OK-NOT-CONFIRMED
                       OR   TTUP-SHOW-DETAILS
                       OR   TTUP-DETAILS-NOT-FOUND
                       OR   TTUP-CONFIRM-DELETE
                       OR   TTUP-CREATE-NEW-RECORD
                            )
      )
       SET PFK-VALID                  TO TRUE
    ELSE
       SET PFK-INVALID                TO TRUE
       IF WS-RETURN-MSG-OFF
          SET WS-INVALID-KEY-PRESSED  TO TRUE
       END-IF
    END-IF


*>    IF PFK-INVALID
*>      SET WS-INVALID-KEY  TO TRUE
*>      SET CCARD-AID-ENTER TO TRUE
*>    ELSE
*>      CONTINUE
*>    END-IF

    .


0001-CHECK-PFKEYS-EXIT.
    EXIT
    .

1000-PROCESS-INPUTS.
    PERFORM 1100-RECEIVE-MAP
       THRU 1100-RECEIVE-MAP-EXIT
    PERFORM 1150-STORE-MAP-IN-NEW
       THRU 1150-STORE-MAP-IN-NEW-EXIT
    PERFORM 1200-EDIT-MAP-INPUTS
       THRU 1200-EDIT-MAP-INPUTS-EXIT
    MOVE WS-RETURN-MSG  TO CCARD-ERROR-MSG
    MOVE LIT-THISPGM    TO CCARD-NEXT-PROG
    MOVE LIT-THISMAPSET TO CCARD-NEXT-MAPSET
    MOVE LIT-THISMAP    TO CCARD-NEXT-MAP
    .
*>
1000-PROCESS-INPUTS-EXIT.
    EXIT
    .
1100-RECEIVE-MAP.
    EXEC CICS RECEIVE MAP(LIT-THISMAP)
              MAPSET(LIT-THISMAPSET)
              INTO(CTRTUPAI)
              RESP(WS-RESP-CD)
              RESP2(WS-REAS-CD)
    END-EXEC
    .
1100-RECEIVE-MAP-EXIT.
    EXIT.

1150-STORE-MAP-IN-NEW.

    IF  TTUP-DETAILS-NOT-FOUND
    AND NOT CCARD-AID-PFK05
    AND FUNCTION TRIM(TRTYPCDI OF CTRTUPAI)
          = TTUP-NEW-TTYP-TYPE
        GO TO 1150-STORE-MAP-IN-NEW-EXIT
    ELSE
        CONTINUE
    END-IF

    INITIALIZE TTUP-NEW-DETAILS
*>*****************************************************************
*>    Transaction Type
*>*****************************************************************
    IF  TRTYPCDI OF CTRTUPAI = '*'
    OR  TRTYPCDI OF CTRTUPAI = SPACES
        MOVE LOW-VALUES           TO TTUP-NEW-TTYP-TYPE
    ELSE
        MOVE FUNCTION TRIM(TRTYPCDI OF CTRTUPAI)
                                  TO TTUP-NEW-TTYP-TYPE
    END-IF

*>*****************************************************************
*>    Transaction Desc
*>*****************************************************************
    IF  TRTYDSCI OF CTRTUPAI = '*'
    OR  TRTYDSCI OF CTRTUPAI = SPACES
        MOVE LOW-VALUES           TO TTUP-NEW-TTYP-TYPE-DESC
    ELSE
        MOVE FUNCTION TRIM(TRTYDSCI OF CTRTUPAI)
                                  TO TTUP-NEW-TTYP-TYPE-DESC
    END-IF
    .
1150-STORE-MAP-IN-NEW-EXIT.
    EXIT
    .
1200-EDIT-MAP-INPUTS.
    SET INPUT-OK                  TO TRUE
*>*****************************************************************
*>    VALIDATE THE SEARCH KEYS
*>*****************************************************************
*>    The key  was not in database. User sent the same key. So
*>    dont edit again. Set tran filter to valid and skip
*>    rest of edits
*>
    IF  TTUP-DETAILS-NOT-FOUND
    AND FUNCTION TRIM(TRTYPCDI OF CTRTUPAI)
          = TTUP-NEW-TTYP-TYPE
        IF CCARD-AID-PFK05
           CONTINUE
        ELSE
           SET TTUP-DETAILS-NOT-FETCHED    TO TRUE
        END-IF
        SET FLG-TRANFILTER-ISVALID         TO TRUE
        GO TO 1200-EDIT-MAP-INPUTS-EXIT
    ELSE
        CONTINUE
    END-IF

    IF  TTUP-CREATE-NEW-RECORD
    OR  TTUP-CHANGES-OK-NOT-CONFIRMED
        CONTINUE
    ELSE
        PERFORM 1210-EDIT-TRANTYPE
           THRU 1210-EDIT-TRANTYPE-EXIT

*>        IF THE SEARCH CONDITIONS HAVE PROBLEMS FLAG THEM
        IF  FLG-TRANFILTER-BLANK
            IF WS-RETURN-MSG-OFF
               SET NO-SEARCH-CRITERIA-RECEIVED TO TRUE
            END-IF
            SET TTUP-DETAILS-NOT-FETCHED       TO TRUE
            GO TO 1200-EDIT-MAP-INPUTS-EXIT
        END-IF

        IF  FLG-TRANFILTER-NOT-OK
            SET TTUP-INVALID-SEARCH-KEYS       TO TRUE
            SET TTUP-DETAILS-NOT-FETCHED       TO TRUE
            GO TO 1200-EDIT-MAP-INPUTS-EXIT
        END-IF

        IF TTUP-DETAILS-NOT-FETCHED
           GO TO 1200-EDIT-MAP-INPUTS-EXIT
        END-IF
    END-IF
*>*****************************************************************
*>    SEARCH KEYS ALREADY VALIDATED. CHECK OTHER INPUTS
*>*****************************************************************
    SET FLG-TRANFILTER-ISVALID    TO TRUE
*>
    PERFORM 1205-COMPARE-OLD-NEW
       THRU 1205-COMPARE-OLD-NEW-EXIT

    IF  NO-CHANGES-FOUND
    OR  TTUP-CHANGES-OK-NOT-CONFIRMED
    OR  TTUP-CHANGES-OKAYED-AND-DONE
        MOVE LOW-VALUES           TO WS-NON-KEY-FLAGS
        GO TO 1200-EDIT-MAP-INPUTS-EXIT
    END-IF

    SET TTUP-CHANGES-NOT-OK       TO TRUE

*>*****************************************************************
*>    Edit Description
*>*****************************************************************
    MOVE 'Transaction Desc'       TO WS-EDIT-VARIABLE-NAME
    MOVE TTUP-NEW-TTYP-TYPE-DESC  TO WS-EDIT-ALPHANUM-ONLY
    MOVE 50                       TO WS-EDIT-ALPHANUM-LENGTH
    PERFORM 1230-EDIT-ALPHANUM-REQD
       THRU 1230-EDIT-ALPHANUM-REQD-EXIT
    MOVE WS-EDIT-ALPHANUM-ONLY-FLAGS
                                  TO WS-EDIT-DESC-FLAGS

*>    Cross field edits begin here
*>
*>       No cross edits in this program so far

*>    Set green light for confirmation if no errors found

    IF INPUT-ERROR
       CONTINUE
    ELSE
       SET TTUP-CHANGES-OK-NOT-CONFIRMED TO TRUE
    END-IF
    .

1200-EDIT-MAP-INPUTS-EXIT.
    EXIT
    .

1205-COMPARE-OLD-NEW.
    SET NO-CHANGES-FOUND           TO TRUE

    IF  FUNCTION UPPER-CASE (
        TTUP-NEW-TTYP-TYPE)    =
        FUNCTION UPPER-CASE (
        TTUP-OLD-TTYP-TYPE)
    AND FUNCTION UPPER-CASE (
        FUNCTION TRIM (TTUP-NEW-TTYP-TYPE-DESC))=
        FUNCTION UPPER-CASE (
        FUNCTION TRIM (TTUP-OLD-TTYP-TYPE-DESC))
    AND FUNCTION LENGTH (
        FUNCTION TRIM (TTUP-NEW-TTYP-TYPE-DESC))=
        FUNCTION LENGTH (
        FUNCTION TRIM (TTUP-OLD-TTYP-TYPE-DESC))

        IF WS-RETURN-MSG-OFF
           SET NO-CHANGES-DETECTED   TO TRUE
        ELSE
           CONTINUE
        END-IF
    ELSE
        IF WS-RETURN-MSG-OFF
           SET CHANGE-HAS-OCCURRED   TO TRUE
        ELSE
            CONTINUE
        END-IF
        GO TO 1205-COMPARE-OLD-NEW-EXIT
    END-IF
    .

1205-COMPARE-OLD-NEW-EXIT.
    EXIT
    .


*>
1210-EDIT-TRANTYPE.
    SET FLG-TRANFILTER-NOT-OK    TO TRUE

*>*****************************************************************
*>    Edit Tran Type code
*>*****************************************************************
    MOVE 'Tran Type code'         TO WS-EDIT-VARIABLE-NAME
    MOVE TTUP-NEW-TTYP-TYPE       TO WS-EDIT-ALPHANUM-ONLY
    MOVE 2                        TO WS-EDIT-ALPHANUM-LENGTH
    PERFORM 1245-EDIT-NUM-REQD
       THRU 1245-EDIT-NUM-REQD-EXIT
    MOVE WS-EDIT-ALPHANUM-ONLY-FLAGS
                                  TO WS-EDIT-TTYP-FLAG

    IF FLG-TRANFILTER-ISVALID
       COMPUTE WS-EDIT-NUMERIC-2
            = FUNCTION NUMVAL(TTUP-NEW-TTYP-TYPE)
       END-COMPUTE
       MOVE WS-EDIT-NUMERIC-2      TO WS-EDIT-ALPHANUMERIC-2
       INSPECT WS-EDIT-ALPHANUMERIC-2
               REPLACING ALL SPACES BY ZEROS
       MOVE WS-EDIT-ALPHANUMERIC-2 TO TTUP-NEW-TTYP-TYPE
    END-IF
    .

1210-EDIT-TRANTYPE-EXIT.
    EXIT
    .

1230-EDIT-ALPHANUM-REQD.
*>    Initialize
    SET FLG-ALPHNANUM-NOT-OK          TO TRUE

*>    Not supplied
    IF WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH)
                                      EQUAL LOW-VALUES
    OR WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH)
        EQUAL SPACES
    OR FUNCTION LENGTH(FUNCTION TRIM(
       WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH))) = 0

       SET INPUT-ERROR                TO TRUE
       SET FLG-ALPHNANUM-BLANK        TO TRUE
       IF WS-RETURN-MSG-OFF
          STRING
            FUNCTION TRIM(WS-EDIT-VARIABLE-NAME)
            ' must be supplied.'
            DELIMITED BY SIZE
            INTO WS-RETURN-MSG
          END-STRING
       END-IF

       GO TO  1230-EDIT-ALPHANUM-REQD-EXIT
    END-IF

*>    Only Alphabets,numbers and space allowed
    MOVE LIT-ALL-ALPHANUM-FROM-X TO LIT-ALL-ALPHANUM-FROM

    INSPECT WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH)
      CONVERTING LIT-ALL-ALPHANUM-FROM
              TO LIT-ALPHANUM-SPACES-TO

    IF FUNCTION LENGTH(
            FUNCTION TRIM(
            WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH)
                           )) = 0
       CONTINUE
    ELSE
       SET INPUT-ERROR           TO TRUE
       SET FLG-ALPHNANUM-NOT-OK  TO TRUE
       IF WS-RETURN-MSG-OFF
          STRING
            FUNCTION TRIM(WS-EDIT-VARIABLE-NAME)
            ' can have numbers or alphabets only.'
            DELIMITED BY SIZE
            INTO WS-RETURN-MSG
          END-STRING
       END-IF
       GO TO  1230-EDIT-ALPHANUM-REQD-EXIT
    END-IF

    SET FLG-ALPHNANUM-ISVALID    TO TRUE
    .
1230-EDIT-ALPHANUM-REQD-EXIT.
    EXIT
    .

1245-EDIT-NUM-REQD.
*>    Initialize
    SET FLG-ALPHNANUM-NOT-OK          TO TRUE

*>    Not supplied
    IF WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH)
                                      EQUAL LOW-VALUES
    OR WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH)
        EQUAL SPACES
    OR FUNCTION LENGTH(FUNCTION TRIM(
       WS-EDIT-ALPHANUM-ONLY(1:WS-EDIT-ALPHANUM-LENGTH))) = 0

       SET INPUT-ERROR                TO TRUE
       SET FLG-ALPHNANUM-BLANK        TO TRUE
       IF WS-RETURN-MSG-OFF
          STRING
            FUNCTION TRIM(WS-EDIT-VARIABLE-NAME)
            ' must be supplied.'
            DELIMITED BY SIZE
            INTO WS-RETURN-MSG
          END-STRING
       END-IF
       GO TO  1245-EDIT-NUM-REQD-EXIT
    END-IF

*>    Only all numeric allowed

    IF FUNCTION TEST-NUMVAL(WS-EDIT-ALPHANUM-ONLY(1:
                            WS-EDIT-ALPHANUM-LENGTH)) = 0
       CONTINUE
    ELSE
       SET INPUT-ERROR           TO TRUE
       SET FLG-ALPHNANUM-NOT-OK  TO TRUE
       IF WS-RETURN-MSG-OFF
          STRING
            FUNCTION TRIM(WS-EDIT-VARIABLE-NAME)
            ' must be numeric.'
            DELIMITED BY SIZE
            INTO WS-RETURN-MSG
          END-STRING
       END-IF
       GO TO  1245-EDIT-NUM-REQD-EXIT
    END-IF
*>

*>    Must not be zero

    IF FUNCTION NUMVAL(WS-EDIT-ALPHANUM-ONLY(1:
                       WS-EDIT-ALPHANUM-LENGTH)) = 0
       SET INPUT-ERROR           TO TRUE
       SET FLG-ALPHNANUM-NOT-OK  TO TRUE
       IF WS-RETURN-MSG-OFF
          STRING
            FUNCTION TRIM(WS-EDIT-VARIABLE-NAME)
            ' must not be zero.'
            DELIMITED BY SIZE
            INTO WS-RETURN-MSG
          END-STRING
       END-IF
       GO TO  1245-EDIT-NUM-REQD-EXIT
    ELSE
       CONTINUE
    END-IF


    SET FLG-ALPHNANUM-ISVALID    TO TRUE
    .
1245-EDIT-NUM-REQD-EXIT.
    EXIT
    .

2000-DECIDE-ACTION.
    EVALUATE TRUE
*>*****************************************************************
*>       NO DETAILS SHOWN.
*>       SO GET THEM AND SETUP DETAIL EDIT SCREEN
*>*****************************************************************
       WHEN TTUP-DETAILS-NOT-FETCHED
*>*****************************************************************
*>       CHANGES MADE. BUT USER CANCELS
*>*****************************************************************
       WHEN CCARD-AID-PFK12
          IF  FLG-TRANFILTER-ISVALID
              SET WS-RETURN-MSG-OFF               TO TRUE
              PERFORM 9000-READ-TRANTYPE
                 THRU 9000-READ-TRANTYPE-EXIT
              IF FOUND-TRANTYPE-IN-TABLE
                 SET TTUP-SHOW-DETAILS            TO TRUE
              ELSE
                 SET TTUP-DETAILS-NOT-FOUND       TO TRUE
              END-IF
          ELSE
              EVALUATE TRUE
                 WHEN TTUP-CONFIRM-DELETE
                  SET WS-DELETE-WAS-CANCELLED     TO TRUE
                  SET TTUP-DETAILS-NOT-FETCHED    TO TRUE
                 WHEN TTUP-CHANGES-OK-NOT-CONFIRMED
                  SET WS-UPDATE-WAS-CANCELLED     TO TRUE
                  SET TTUP-CHANGES-BACKED-OUT     TO TRUE
                 WHEN OTHER
                  SET TTUP-DETAILS-NOT-FETCHED    TO TRUE
              END-EVALUATE

          END-IF
*>*****************************************************************
*>       DETAILS SHOWN
*>       BUT USER PRESSES F4 FOR DELETE
*>       ASK THE USER TO CONFIRM THE DELETE
*>*****************************************************************
       WHEN TTUP-CONFIRM-DELETE
        AND CCARD-AID-PFK12
          SET TTUP-CONFIRM-DELETE                 TO TRUE
*>*****************************************************************
*>       DETAILS SHOWN
*>       CHECK CHANGES AND ASK CONFIRMATION IF GOOD
*>*****************************************************************
       WHEN TTUP-SHOW-DETAILS
          IF INPUT-ERROR
          OR NO-CHANGES-DETECTED
          OR WS-INVALID-KEY
             CONTINUE
          ELSE
             SET TTUP-CHANGES-OK-NOT-CONFIRMED TO TRUE
          END-IF
*>*****************************************************************
*>       DETAILS SHOWN
*>       BUT INPUT EDIT ERRORS FOUND
*>*****************************************************************
       WHEN TTUP-CHANGES-NOT-OK
           CONTINUE
*>*****************************************************************
*>       CHANGES BACKED OUT
*>       GO BACK TO CHANGES NOT OK STATE
*>*****************************************************************
       WHEN TTUP-CHANGES-BACKED-OUT
           SET TTUP-CHANGES-NOT-OK            TO TRUE
*>*****************************************************************
*>       PROBLEMS FOUND IN SEARCH KEYS
*>*****************************************************************
       WHEN TTUP-INVALID-SEARCH-KEYS
           CONTINUE
*>*****************************************************************
*>       SEARCH KEY WAS VALID.
*>       BUT DATA WAS NOT FOUND IN TABLE
*>       CUSTOMER DECIDES TO CONTINUE AND ADD RECORD
*>*****************************************************************
       WHEN CCARD-AID-PFK05
        AND TTUP-DETAILS-NOT-FOUND
           SET TTUP-CREATE-NEW-RECORD TO TRUE
*>*****************************************************************
*>       DETAILS EDITED , FOUND OK, CONFIRM SAVE REQUESTED
*>       CONFIRMATION NOT GIVEN. SO SHOW DETAILS AGAIN
*>*****************************************************************
       WHEN TTUP-CHANGES-OK-NOT-CONFIRMED
           CONTINUE
*>*****************************************************************
*>       SHOW CONFIRMATION. GO BACK TO SQUARE 1
*>*****************************************************************
       WHEN TTUP-CHANGES-OKAYED-AND-DONE
           SET TTUP-SHOW-DETAILS TO TRUE
           IF CDEMO-FROM-TRANID    EQUAL LOW-VALUES
           OR CDEMO-FROM-TRANID    EQUAL SPACES
              MOVE ZEROES       TO CDEMO-ACCT-ID
                                   CDEMO-CARD-NUM
              MOVE LOW-VALUES   TO CDEMO-ACCT-STATUS
           END-IF
       WHEN OTHER
            MOVE LIT-THISPGM    TO ABEND-CULPRIT
            MOVE '0001'         TO ABEND-CODE
            MOVE SPACES         TO ABEND-REASON
            MOVE 'UNEXPECTED DATA SCENARIO'
                                TO ABEND-MSG
            PERFORM ABEND-ROUTINE
               THRU ABEND-ROUTINE-EXIT
    END-EVALUATE
    .
2000-DECIDE-ACTION-EXIT.
    EXIT
    .



3000-SEND-MAP.
    PERFORM 3100-SCREEN-INIT
       THRU 3100-SCREEN-INIT-EXIT
    PERFORM 3200-SETUP-SCREEN-VARS
       THRU 3200-SETUP-SCREEN-VARS-EXIT
    PERFORM 3250-SETUP-INFOMSG
       THRU 3250-SETUP-INFOMSG-EXIT
    PERFORM 3300-SETUP-SCREEN-ATTRS
       THRU 3300-SETUP-SCREEN-ATTRS-EXIT
    PERFORM 3390-SETUP-INFOMSG-ATTRS
       THRU 3390-SETUP-INFOMSG-ATTRS-EXIT
    PERFORM 3391-SETUP-PFKEY-ATTRS
       THRU 3391-SETUP-PFKEY-ATTRS-EXIT
    PERFORM 3400-SEND-SCREEN
       THRU 3400-SEND-SCREEN-EXIT
    .

3000-SEND-MAP-EXIT.
    EXIT
    .

3100-SCREEN-INIT.
    MOVE LOW-VALUES                TO CTRTUPAO

    MOVE FUNCTION CURRENT-DATE     TO WS-CURDATE-DATA

    MOVE CCDA-TITLE01              TO TITLE01O OF CTRTUPAO
    MOVE CCDA-TITLE02              TO TITLE02O OF CTRTUPAO
    MOVE LIT-THISTRANID            TO TRNNAMEO OF CTRTUPAO
    MOVE LIT-THISPGM               TO PGMNAMEO OF CTRTUPAO

    MOVE FUNCTION CURRENT-DATE     TO WS-CURDATE-DATA

    MOVE WS-CURDATE-MONTH          TO WS-CURDATE-MM
    MOVE WS-CURDATE-DAY            TO WS-CURDATE-DD
    MOVE WS-CURDATE-YEAR(3:2)      TO WS-CURDATE-YY

    MOVE WS-CURDATE-MM-DD-YY       TO CURDATEO OF CTRTUPAO

    MOVE WS-CURTIME-HOURS          TO WS-CURTIME-HH
    MOVE WS-CURTIME-MINUTE         TO WS-CURTIME-MM
    MOVE WS-CURTIME-SECOND         TO WS-CURTIME-SS

    MOVE WS-CURTIME-HH-MM-SS       TO CURTIMEO OF CTRTUPAO

    .

3100-SCREEN-INIT-EXIT.
    EXIT
    .

3200-SETUP-SCREEN-VARS.
*>    INITIALIZE SEARCH CRITERIA
    IF CDEMO-PGM-ENTER
       CONTINUE
    ELSE
       EVALUATE TRUE
        WHEN TTUP-DETAILS-NOT-FETCHED
           PERFORM 3201-SHOW-INITIAL-VALUES
              THRU 3201-SHOW-INITIAL-VALUES-EXIT
        WHEN TTUP-SHOW-DETAILS
        WHEN TTUP-CONFIRM-DELETE
        WHEN TTUP-DELETE-FAILED
        WHEN TTUP-DELETE-DONE
        WHEN TTUP-CHANGES-BACKED-OUT
           INITIALIZE TTUP-NEW-DETAILS
           PERFORM 3202-SHOW-ORIGINAL-VALUES
              THRU 3202-SHOW-ORIGINAL-VALUES-EXIT
        WHEN TTUP-CHANGES-MADE
        WHEN TTUP-CHANGES-NOT-OK
        WHEN TTUP-DETAILS-NOT-FOUND
        WHEN TTUP-INVALID-SEARCH-KEYS
        WHEN TTUP-CREATE-NEW-RECORD
        WHEN TTUP-CHANGES-OKAYED-AND-DONE
           PERFORM 3203-SHOW-UPDATED-VALUES
              THRU 3203-SHOW-UPDATED-VALUES-EXIT
        WHEN OTHER
           INITIALIZE TTUP-NEW-DETAILS
           PERFORM 3202-SHOW-ORIGINAL-VALUES
              THRU 3202-SHOW-ORIGINAL-VALUES-EXIT
       END-EVALUATE
     END-IF
    .
3200-SETUP-SCREEN-VARS-EXIT.
    EXIT
    .

3201-SHOW-INITIAL-VALUES.
    MOVE LOW-VALUES                     TO  TRTYPCDO OF CTRTUPAO
                                            TRTYPCDO OF CTRTUPAO
    .

3201-SHOW-INITIAL-VALUES-EXIT.
    EXIT
    .

3202-SHOW-ORIGINAL-VALUES.

    MOVE LOW-VALUES                     TO WS-NON-KEY-FLAGS

    MOVE TTUP-OLD-TTYP-TYPE             TO TRTYPCDO OF CTRTUPAO
    MOVE TTUP-OLD-TTYP-TYPE-DESC        TO TRTYDSCO OF CTRTUPAO

    .

3202-SHOW-ORIGINAL-VALUES-EXIT.
    EXIT
    .
3203-SHOW-UPDATED-VALUES.

    MOVE TTUP-NEW-TTYP-TYPE             TO TRTYPCDO OF CTRTUPAO
    MOVE TTUP-NEW-TTYP-TYPE-DESC        TO TRTYDSCO OF CTRTUPAO
    .

3203-SHOW-UPDATED-VALUES-EXIT.
    EXIT
    .




3250-SETUP-INFOMSG.
*>    SETUP INFORMATION MESSAGE

        EVALUATE TRUE
        WHEN CDEMO-PGM-ENTER
             SET  PROMPT-FOR-SEARCH-KEYS    TO TRUE
        WHEN TTUP-DETAILS-NOT-FETCHED
        WHEN TTUP-INVALID-SEARCH-KEYS
             SET PROMPT-FOR-SEARCH-KEYS     TO TRUE
        WHEN TTUP-DETAILS-NOT-FOUND
             SET PROMPT-CREATE-NEW-RECORD   TO TRUE
        WHEN TTUP-SHOW-DETAILS
        WHEN TTUP-CHANGES-BACKED-OUT
        AND (TTUP-OLD-TTYP-TYPE    = LOW-VALUES
        OR   TTUP-OLD-TTYP-TYPE    = SPACES)
             SET  PROMPT-FOR-SEARCH-KEYS    TO TRUE
        WHEN TTUP-CHANGES-BACKED-OUT
        WHEN TTUP-CHANGES-NOT-OK
             SET PROMPT-FOR-CHANGES         TO TRUE
        WHEN TTUP-CONFIRM-DELETE
             SET PROMPT-DELETE-CONFIRM      TO TRUE
        WHEN TTUP-DELETE-FAILED
             SET INFORM-FAILURE             TO TRUE
        WHEN TTUP-DELETE-DONE
             SET CONFIRM-DELETE-SUCCESS     TO TRUE
        WHEN TTUP-CREATE-NEW-RECORD
             SET PROMPT-FOR-NEWDATA         TO TRUE
        WHEN TTUP-CHANGES-OK-NOT-CONFIRMED
             SET PROMPT-FOR-CONFIRMATION    TO TRUE
        WHEN TTUP-CHANGES-OKAYED-AND-DONE
             SET CONFIRM-UPDATE-SUCCESS     TO TRUE
        WHEN TTUP-CHANGES-OKAYED-LOCK-ERROR
             SET INFORM-FAILURE             TO TRUE
        WHEN TTUP-CHANGES-OKAYED-BUT-FAILED
             SET INFORM-FAILURE             TO TRUE
        WHEN WS-NO-INFO-MESSAGE
            SET PROMPT-FOR-SEARCH-KEYS      TO TRUE
    END-EVALUATE

*> Center justify the text
*>
    COMPUTE WS-STRING-LEN =
            FUNCTION LENGTH(
                     FUNCTION TRIM(WS-INFO-MSG)
                           )
    COMPUTE WS-STRING-MID =
           (FUNCTION LENGTH(WS-INFO-MSG)
                         - WS-STRING-LEN) / 2 + 1
    MOVE WS-INFO-MSG(1:WS-STRING-LEN)
      TO WS-STRING-OUT(WS-STRING-MID:
                       WS-STRING-LEN)

    MOVE WS-STRING-OUT                  TO INFOMSGO OF CTRTUPAO

    MOVE WS-RETURN-MSG                  TO ERRMSGO  OF CTRTUPAO
    .
3250-SETUP-INFOMSG-EXIT.
    EXIT
    .
3300-SETUP-SCREEN-ATTRS.

*>    PROTECT ALL FIELDS
    PERFORM 3310-PROTECT-ALL-ATTRS
       THRU 3310-PROTECT-ALL-ATTRS-EXIT

*>    UNPROTECT BASED ON CONTEXT
    EVALUATE TRUE
       WHEN TTUP-DETAILS-NOT-FETCHED
       WHEN TTUP-INVALID-SEARCH-KEYS
       WHEN TTUP-DETAILS-NOT-FOUND
       WHEN TTUP-CHANGES-BACKED-OUT
        AND (TTUP-OLD-TTYP-TYPE    = LOW-VALUES
        OR   TTUP-OLD-TTYP-TYPE    = SPACES)
*>            Make Search Keys editable
            MOVE DFHBMFSE      TO TRTYPCDA OF CTRTUPAI
       WHEN TTUP-SHOW-DETAILS
       WHEN TTUP-CHANGES-NOT-OK
       WHEN TTUP-CREATE-NEW-RECORD
       WHEN TTUP-CHANGES-BACKED-OUT
            PERFORM 3320-UNPROTECT-FEW-ATTRS
               THRU 3320-UNPROTECT-FEW-ATTRS-EXIT
       WHEN TTUP-CHANGES-OK-NOT-CONFIRMED
       WHEN TTUP-CHANGES-OKAYED-AND-DONE
       WHEN TTUP-DELETE-IN-PROGRESS
*>            Keep all fields protected
            CONTINUE
       WHEN OTHER
            MOVE DFHBMFSE      TO TRTYPCDA OF CTRTUPAI
    END-EVALUATE

*>*****************************************************************
*>    POSITION CURSOR - ORDER BASED ON SCREEN LOCATION
*>*****************************************************************
    EVALUATE TRUE
       WHEN TTUP-DETAILS-NOT-FETCHED
       WHEN TTUP-DETAILS-NOT-FOUND
       WHEN TTUP-INVALID-SEARCH-KEYS
       WHEN FLG-TRANFILTER-NOT-OK
       WHEN FLG-TRANFILTER-BLANK
       WHEN TTUP-CHANGES-OKAYED-AND-DONE
       WHEN TTUP-CHANGES-BACKED-OUT
        AND (TTUP-OLD-TTYP-TYPE    = LOW-VALUES
        OR   TTUP-OLD-TTYP-TYPE    = SPACES)
            MOVE -1             TO TRTYPCDL OF CTRTUPAI
*>    Description
       WHEN TTUP-CREATE-NEW-RECORD
       WHEN NO-CHANGES-DETECTED
       WHEN FLG-DESCRIPTION-NOT-OK
       WHEN FLG-DESCRIPTION-BLANK
       WHEN TTUP-CHANGES-MADE
       WHEN TTUP-CHANGES-BACKED-OUT
       WHEN TTUP-SHOW-DETAILS
           MOVE -1              TO TRTYDSCL OF CTRTUPAI
       WHEN OTHER
           MOVE -1              TO TRTYPCDL OF CTRTUPAI
     END-EVALUATE

*>*****************************************************************
*>    SETUP COLOR
*>*****************************************************************
*>    Transaction Type code filer
    IF FLG-TRANFILTER-NOT-OK
    OR TTUP-DELETE-FAILED
       MOVE DFHRED              TO TRTYPCDC OF CTRTUPAO
    END-IF

    IF  FLG-TRANFILTER-BLANK
    AND CDEMO-PGM-REENTER
        MOVE '*'                TO TRTYPCDO OF CTRTUPAO
        MOVE DFHRED             TO TRTYPCDC OF CTRTUPAO
    END-IF

    IF TTUP-DETAILS-NOT-FETCHED
    OR TTUP-DETAILS-NOT-FOUND
    OR TTUP-INVALID-SEARCH-KEYS
    OR FLG-TRANFILTER-BLANK
    OR FLG-TRANFILTER-NOT-OK
       GO TO 3300-SETUP-SCREEN-ATTRS-EXIT
    ELSE
       CONTINUE
    END-IF

*>*****************************************************************
*>    Using Copy replacing to set attribs for remaining vars
*>    Write specific code only if rules differ
*>*****************************************************************

*>    Transaction Description Status
*>    COPY CSSETATY REPLACING
*>      ==(TESTVAR1)== BY ==DESCRIPTION==
*>      ==(SCRNVAR2)== BY ==TRTYDSC==
*>      ==(MAPNAME3)== BY ==CTRTUPA== .
*>vvv-> file: C:\Users\Sethulekshmi.Pishara\Work\LiberTools\CLERITY\Converter\aws_cards_demo\sources\cpy\CSSETATY.cpy
*>*****************************************************************
